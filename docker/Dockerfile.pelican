FROM python:3.12-slim

LABEL maintainer="SSG Benchmark"
LABEL description="Pelican SSG Benchmark Environment"

# Install dependencies
RUN apt-get update && apt-get install -y \
    bash \
    coreutils \
    && rm -rf /var/lib/apt/lists/*

# Install Pelican with Markdown support
RUN pip install --no-cache-dir "pelican[markdown]"

# Set working directory
WORKDIR /site

# Default command
CMD ["pelican", "content", "-s", "pelicanconf.py"]
