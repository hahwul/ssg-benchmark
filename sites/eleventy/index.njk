---
layout: default.njk
title: SSG Benchmark Site
---
<section class="home">
    <h1>SSG Benchmark Site</h1>
    <p>Benchmark site for testing SSG performance</p>

    <h2>Recent Posts</h2>
    <ul class="posts-list">
    {% for post in collections.post | reverse %}
        {% if loop.index <= 10 %}
        <li>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            <time datetime="{{ post.date | date: '%Y-%m-%d' }}">
                {{ post.date | date: '%B %d, %Y' }}
            </time>
        </li>
        {% endif %}
    {% endfor %}
    </ul>
</section>
