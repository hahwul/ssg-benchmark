---
layout: default.njk
title: Posts
permalink: posts/index.html
---
<section class="section">
    <h1>Posts</h1>
    <ul class="posts-list">
    {%- for post in collections.post %}
        <li>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            <time datetime="{{ post.date | dateFormat('iso') }}">
                {{ post.date | dateFormat }}
            </time>
        </li>
    {%- endfor %}
    </ul>
</section>
