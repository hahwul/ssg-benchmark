---
layout: default.njk
---
<article>
    <header>
        <h1>{{ title }}</h1>
        {% if date %}
        <time datetime="{{ date | dateFormat('iso') }}">
            {{ date | dateFormat }}
        </time>
        {% endif %}
        {% if tags %}
        <div class="tags">
            {% for tag in tags %}
            <span class="tag">{{ tag }}</span>
            {% endfor %}
        </div>
        {% endif %}
    </header>
    <div class="content">
        {{ content | safe }}
    </div>
</article>
