---
const { title = "SSG Benchmark Site" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content="Benchmark site for testing SSG performance">
</head>
<body>
    <header>
        <h1>SSG Benchmark Site</h1>
        <nav>
            <a href="/">Home</a>
        </nav>
    </header>
    <main>
        <slot />
    </main>
    <footer>
        <p>&copy; SSG Benchmark</p>
    </footer>
</body>
</html>
