<article>
    <header>
        <h1><%= page.title %></h1>
        <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>">
            <%= date(page.date, 'MMMM DD, YYYY') %>
        </time>
        <% if (page.tags && page.tags.length) { %>
        <div class="tags">
            <% page.tags.forEach(function(tag) { %>
            <span class="tag"><%= tag.name %></span>
            <% }); %>
        </div>
        <% } %>
    </header>
    <div class="content">
        <%- page.content %>
    </div>
    <nav class="post-nav">
        <% if (page.prev) { %><a class="post-nav-prev" href="<%- url_for(page.prev.path) %>">&larr; <%= page.prev.title %></a><% } %>
        <% if (page.next) { %><a class="post-nav-next" href="<%- url_for(page.next.path) %>"><%= page.next.title %> &rarr;</a><% } %>
    </nav>
</article>
