<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("SSG Benchmark Site") }}</title>
    <meta name="description" content="Benchmark site for testing SSG performance">
</head>
<body>
    <header>
        <h1>SSG Benchmark Site</h1>
        <nav class="breadcrumbs">
            <a href="/">Home</a>{% if title %} / <span>{{ title }}</span>{% endif %}
        </nav>
    </header>
    <div class="layout">
        <main>
            {{ content | safe }}
        </main>
        {% include "sidebar.njk" %}
    </div>
    <footer>
        <p>&copy; SSG Benchmark</p>
    </footer>
</body>
</html>
