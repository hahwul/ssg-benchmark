---
layout: default.njk
pagination:
  data: collections
  size: 1
  alias: tag
  filter: ["post", "all", "tagList"]
permalink: "tags/{{ tag }}/index.html"
eleventyComputed:
  title: "Tag: {{ tag }}"
---
<section class="tag-page">
    <h1>Tag: {{ tag }}</h1>
    <ul class="posts-list">
    {%- for post in collections[tag] %}
        <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
    {%- endfor %}
    </ul>
</section>
